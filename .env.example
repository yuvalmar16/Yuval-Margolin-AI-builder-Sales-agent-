# Copy this file to .env.local and fill in the values you have.
# Every variable here is optional — the app falls back to a safe local
# behavior when a variable is unset. Never commit .env.local (it's gitignored).

# OpenAI — used to generate assistant drafts from the builder prompt.
# When unset, the builder falls back to a deterministic default draft
# (src/lib/builder/assistant-draft.ts createDefaultDraft).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Supabase — used as the system of record for assistant versions
# (see docs/milestone-7-database-storage-design.md). When unset, the
# workspace persistence layer falls back to a local file at
# app/.data/workspace.json (src/lib/builder/assistant-workspace.ts).
# NEXT_PUBLIC_SUPABASE_URL is the project URL (not a secret, safe as a
# public var). SUPABASE_SERVICE_ROLE_KEY is server-only and must never
# be exposed to the browser or prefixed with NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vapi — powers the live in-browser voice call demo in the builder
# (see docs/milestone-5-voice-provider-selection.md). This is the "Public
# Key" from your Vapi dashboard, not the Private Key -- it's designed to be
# used client-side. When unset, the "Live voice call" panel shows an error
# instead of starting a call; everything else in the app still works.
NEXT_PUBLIC_VAPI_PUBLIC_KEY=

# Google Calendar — used to create a real calendar event when a meeting is
# booked (see docs/milestone-6-crm-calendar-strategy.md). When unset, or when
# the calendar isn't connected yet, booked meetings stay mock-only (a time +
# reference, no real event) -- everything else in the app still works.
# Create these under a Google Cloud project: enable the "Google Calendar
# API", configure the OAuth consent screen (Testing mode is fine for a
# single-user MVP -- note Google limits unverified apps using this scope to
# a 7-day refresh token, so you may need to reconnect weekly until you verify
# the app), then create an OAuth 2.0 Client ID of type "Web application" with
# GOOGLE_CALENDAR_REDIRECT_URI added as an authorized redirect URI.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/auth/google-calendar/callback
